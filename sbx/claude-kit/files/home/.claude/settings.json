    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Read(//**/.ssh/**)",
      "Read(//**/.aws/**)",
      "Read(//**/.netrc)",
      "Read(//**/.config/gh/hosts.yml)",
      "Bash(gh secret:*)",
      "Bash(gh auth token:*)",
      "Bash(git push *--force*)",
      "Bash(git push *-f)",
      "Bash(git push *-f *)",
      "Bash(git push *-fu*)",
      "Bash(git push *-uf*)",
      "Bash(git push *+*)"
