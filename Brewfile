# Usage: `brew bundle --file=Brewfile` (run from repo root).
# Regenerate on your primary Mac with: `brew bundle dump --describe --file=Brewfile --force`
# See `brew bundle --help` for `--cleanup` and `--no-upgrade`.

# ─── Apps (casks) ────────────────────────────────────────────────────────────
# Install Ghostty from Homebrew so new Macs don't need a manual download.
cask "ghostty"

# Other GUI apps installed locally but not yet tracked here — uncomment as needed:
# cask "google-chrome"
# cask "slack"
# cask "visual-studio-code"

# ─── Fonts ──────────────────────────────────────────────────────────────────
# MonoLisa is a paid font and can't be installed via Homebrew. After buying,
# drop the .otf/.ttf files into ~/Library/Fonts/ or install system-wide.
# Free alternative if MonoLisa isn't available on a given machine:
# cask "font-jetbrains-mono"

# ─── CLI formulas ───────────────────────────────────────────────────────────
# Simple, fast and user-friendly alternative to find
brew "fd"
# Command-line fuzzy finder written in Go
brew "fzf"
# Lightweight and flexible command-line JSON processor
brew "jq"
# Ambitious Vim-fork focused on extensibility and agility
brew "neovim"
# Python version management
brew "pyenv"
# Ruby version manager
brew "rbenv"
# Search tool like grep and The Silver Searcher
brew "ripgrep"
# Terminal multiplexer
brew "tmux"
# Parser generator tool
brew "tree-sitter-cli"
# Tracks most-used directories to make cd smarter
brew "z"