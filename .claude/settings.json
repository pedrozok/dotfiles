{
  "permissions": {
    "allow": [
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh search issues:*)",
      "Bash(gh repo view:*)",
      "Bash(gh label list:*)",
      "Bash(gh label create:*)",
      "Bash(gh label edit:*)",
      "Bash(git log:*)",
      "Bash(git blame:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git ls-files:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run test:*)",
      "Bash(npm run format:check:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npx vitest:*)",
      "Bash(npx playwright test:*)",
      "Write(/tmp/**)",
      "mcp__github"
    ],
    "deny": [
      "Bash(cat .env)",
      "Bash(cat .env.local)",
      "Bash(cat .env.*.local)",
      "Bash(cat .env.*)",
      "Bash(cat ~/.ssh/*)",
      "Bash(cat ~/.aws/credentials)",
      "Bash(cat ~/.aws/config)",
      "Bash(cat ~/.config/gh/hosts.yml)",
      "Bash(cat ~/.netrc)",
      "Bash(gh secret:*)",
      "Bash(gh auth token:*)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh",
    "padding": 0
  },
  "alwaysThinkingEnabled": true,
  "theme": "dark",
  "skipAutoPermissionPrompt": true,
  "effortLevel": "xhigh"
}
